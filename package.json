{
  "name": "campaign-cms",
  "private": true,
  "type": "module",
  "description": "Block-based CMS and page builder for campaign sites on Cloudflare D1/R2 and TanStack Start.",
  "repository": {
    "type": "git",
    "url": "https://github.com/chester-hill-solutions/campaign-cms.git"
  },
  "bugs": {
    "url": "https://github.com/chester-hill-solutions/campaign-cms/issues"
  },
  "homepage": "https://github.com/chester-hill-solutions/campaign-cms#readme",
  "author": "Chester Hill Solutions",
  "license": "MIT",
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "example:setup": "npm run setup:local -w campaign-cms-minimal-site",
    "example:seed": "npm run seed:local -w campaign-cms-minimal-site",
    "example:dev": "npm run dev -w campaign-cms-minimal-site",
    "example:pages:dev": "npm run dev -w campaign-cms-gh-pages",
    "example:pages:build": "VITE_BASE=/campaign-cms/ npm run build -w campaign-cms-gh-pages",
    "typecheck": "npm run typecheck -w campaign-cms-minimal-site && npm run typecheck -w campaign-cms-gh-pages"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@chester-hill-solutions/cms-core": "file:vendor/chs-cms/cms-core",
    "@chester-hill-solutions/cms-server": "file:vendor/chs-cms/cms-server",
    "@chester-hill-solutions/cms-react": "file:vendor/chs-cms/cms-react",
    "@chester-hill-solutions/cms-agent": "file:vendor/chs-cms/cms-agent",
    "@chester-hill-solutions/cms-setup": "file:vendor/chs-cms/cms-setup"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
