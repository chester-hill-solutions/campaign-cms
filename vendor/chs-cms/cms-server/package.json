{
  "name": "@chester-hill-solutions/cms-server",
  "version": "0.1.1",
  "description": "D1/R2-backed CMS persistence: entries, draft/publish revisions, pageDoc storage, media library",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chester-hill-solutions/chester-hill-solutions.git",
    "directory": "packages/cms-server"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@chester-hill-solutions/cms-core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250110.0",
    "bun-types": "^1.3.5",
    "typescript": "^5.9.2"
  }
}
