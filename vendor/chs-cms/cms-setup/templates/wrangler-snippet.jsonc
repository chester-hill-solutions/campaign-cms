// Merge into your wrangler.jsonc. Replace __DB_NAME__, __DB_ID__, __BUCKET_NAME__.
{
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "__DB_NAME__",
      "database_id": "__DB_ID__",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "__BUCKET_NAME__",
    },
  ],
}
