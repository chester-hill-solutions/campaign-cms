{
  "name": "@chester-hill-solutions/cms-core",
  "version": "0.1.1",
  "description": "Framework-agnostic CMS core: pageDoc block schemas, block factory, validation, and slug utilities",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chester-hill-solutions/chester-hill-solutions.git",
    "directory": "packages/cms-core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
